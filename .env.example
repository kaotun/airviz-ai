# ============================================================
# AirViz.AI — Cấu hình môi trường toàn hệ thống
# ------------------------------------------------------------
# Hướng dẫn:
#   1. Copy file này: cp .env.example .env
#   2. Điền các giá trị thật vào file .env
#   3. KHÔNG commit file .env lên git (đã có trong .gitignore)
# ============================================================


# ── DATABASE (TimescaleDB) ───────────────────────────────────
# Tên database, username, password — dùng cho cả Docker và backend
POSTGRES_DB=airviz
POSTGRES_USER=airviz_user
POSTGRES_PASSWORD=your_strong_password_here

# Host nội bộ (Docker network: tên service) — backend dùng tên này
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432


# ── REDIS ───────────────────────────────────────────────────
# URL kết nối Redis — backend dùng để cache query
REDIS_URL=redis://redis:6379


# ── BACKEND ─────────────────────────────────────────────────
# Port backend expose ra ngoài host (truy cập qua localhost:8080)
BACKEND_PORT=8080


# ── AI / GEMINI ─────────────────────────────────────────────
# API Key cho Gemini 1.5 Flash (Text2SQL Engine)
# Lấy key MIỄN PHÍ tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here


# ── FRONTEND (Vite) ─────────────────────────────────────────
# Biến Vite phải có tiền tố VITE_ để được expose ra browser
# URL của backend API — frontend gọi đến đây
VITE_API_BASE_URL=http://localhost:8080/api/v1
